---
const { pathname } = Astro.url;
const isActive = (href: string) => pathname === href || pathname === href + '/';
---
<nav class="sticky top-0 z-40 bg-white/90 backdrop-blur border-b border-slate-100">
  <div class="max-w-5xl mx-auto px-5 py-3 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 font-semibold text-ink">
      <span class="inline-block w-2.5 h-2.5 rounded-sm bg-accent"></span>
      <span>OmicsDesk</span>
    </a>
    <div class="hidden sm:flex items-center gap-6 text-sm text-slate-600">
      <a href="/pricing/" class={`hover:text-ink ${isActive('/pricing') ? 'text-ink font-medium' : ''}`}>Pricing</a>
      <a href="/publications/" class={`hover:text-ink ${isActive('/publications') ? 'text-ink font-medium' : ''}`}>Publications</a>
      <a href="/blog/" class={`hover:text-ink ${pathname.startsWith('/blog') ? 'text-ink font-medium' : ''}`}>Blog</a>
      <a href="/#contact" class="hover:text-ink">Contact</a>
    </div>
    <div class="flex items-center gap-3">
      <a href="https://www.linkedin.com/company/omicsdesk" target="_blank" rel="noopener" aria-label="OmicsDesk on LinkedIn" class="text-slate-500 hover:text-ink">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.05c.47-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/></svg>
      </a>
      <a href="https://submit.omicsdesk.com/" class="text-sm font-medium bg-ink text-white px-3.5 py-1.5 rounded-md hover:bg-slate-800 transition">
        Submit your data
      </a>
    </div>
  </div>
</nav>
