---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('publications', ({ id }) => !id.startsWith('_'));
const sorted = all.sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  return b.data.year - a.data.year;
});
---
<Base
  title="Publications — OmicsDesk"
  description="Peer-reviewed work behind the OmicsDesk service. Each entry: what it solved, what methods were used, why it matters."
>
  <header class="max-w-4xl mx-auto px-5 pt-16 pb-10">
    <p class="text-accent font-medium text-sm tracking-wide uppercase mb-3">Peer-reviewed</p>
    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight">
      The work behind the service.
    </h1>
    <p class="mt-5 text-lg text-slate-600 max-w-2xl leading-relaxed">
      Selected publications behind the methods we run for clients. What each paper solved,
      what was used to solve it, and why it matters for translational decisions.
    </p>
  </header>

  {sorted.length === 0 && (
    <section class="max-w-4xl mx-auto px-5 pb-20">
      <div class="rounded-xl border-2 border-dashed border-slate-200 p-8 md:p-10 bg-slate-50">
        <h2 class="text-lg font-semibold tracking-tight">Publications coming soon</h2>
        <p class="text-sm text-slate-600 mt-2 max-w-xl">
          A formal publications list will appear here. In the meantime, request the sample report or
          email <a href="mailto:hello@omicsdesk.com" class="text-accent underline">hello@omicsdesk.com</a> for examples of past work.
        </p>
      </div>
    </section>
  )}

  <section class="max-w-4xl mx-auto px-5 pb-20 grid gap-5">
    {sorted.map((p) => (
      <article class="bg-white rounded-xl border border-slate-200 p-6">
        <div class="flex items-start justify-between gap-4 flex-wrap">
          <div class="min-w-0">
            <div class="text-xs font-mono uppercase tracking-wide text-slate-500">
              {p.data.venue} · {p.data.year}
            </div>
            <h2 class="text-lg font-semibold text-ink mt-1.5">
              {p.data.title}
            </h2>
            <p class="text-sm text-slate-500 mt-1 italic">{p.data.authors}</p>
          </div>
          {p.data.featured && (
            <span class="text-xs bg-accent/10 text-accent-dark px-2 py-1 rounded font-medium shrink-0">Featured</span>
          )}
        </div>
        <p class="text-sm text-slate-700 mt-4 leading-relaxed">
          <span class="font-semibold text-ink">My role: </span>
          {p.data.role}
        </p>
        <p class="text-sm text-slate-700 mt-3 leading-relaxed">
          <span class="font-semibold text-ink">In plain language: </span>
          {p.data.summary}
        </p>
        {p.data.methods.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-1.5">
            {p.data.methods.map((m) => (
              <span class="text-xs bg-slate-100 text-slate-700 px-2 py-1 rounded">{m}</span>
            ))}
          </div>
        )}
        <div class="mt-5 flex flex-wrap gap-3 text-sm">
          {p.data.url && (
            <a href={p.data.url} target="_blank" rel="noopener" class="text-accent font-medium hover:underline">
              Read paper →
            </a>
          )}
          {p.data.doi && (
            <a href={`https://doi.org/${p.data.doi}`} target="_blank" rel="noopener" class="text-slate-500 hover:text-ink font-mono text-xs">
              DOI: {p.data.doi}
            </a>
          )}
          {p.data.pdfUrl && (
            <a href={p.data.pdfUrl} target="_blank" rel="noopener" class="text-slate-500 hover:text-ink font-medium">
              PDF
            </a>
          )}
        </div>
      </article>
    ))}
  </section>
</Base>
