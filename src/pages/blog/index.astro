---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const isProd = import.meta.env.PROD;
const all = await getCollection('blog', ({ data }) => !isProd || !data.draft);
const sorted = all.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Base
  title="Blog — OmicsDesk"
  description="Practical, technical posts on bioinformatics workflows: tool comparisons, troubleshooting guides, and field notes from real client work."
>
  <header class="max-w-4xl mx-auto px-5 pt-16 pb-10">
    <p class="text-accent font-medium text-sm tracking-wide uppercase mb-3">Notes from the bench</p>
    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight">
      Bioinformatics, with the receipts.
    </h1>
    <p class="mt-5 text-lg text-slate-600 max-w-2xl leading-relaxed">
      Specific troubleshooting, tool comparisons, and workflow notes from real client projects.
      No "intro to RNA-seq" — only the parts that actually trip people up.
    </p>
  </header>

  {sorted.length === 0 && (
    <section class="max-w-4xl mx-auto px-5 pb-20">
      <div class="rounded-xl border-2 border-dashed border-slate-200 p-8 md:p-10 bg-slate-50">
        <h2 class="text-lg font-semibold tracking-tight">First post coming soon</h2>
        <p class="text-sm text-slate-600 mt-2">
          New posts every 2–3 weeks. Check back, or subscribe by emailing
          <a href="mailto:hello@omicsdesk.com" class="text-accent underline">hello@omicsdesk.com</a>.
        </p>
      </div>
    </section>
  )}

  <section class="max-w-4xl mx-auto px-5 pb-20 grid gap-5">
    {sorted.map((post) => (
      <a href={`/blog/${post.slug}/`} class="block bg-white rounded-xl border border-slate-200 p-6 hover:border-accent transition group">
        <div class="text-xs font-mono uppercase tracking-wide text-slate-500">
          {post.data.pubDate.toISOString().slice(0, 10)}
          {post.data.draft && <span class="ml-2 text-amber-600">DRAFT</span>}
        </div>
        <h2 class="text-xl font-semibold text-ink mt-2 group-hover:text-accent transition">
          {post.data.title}
        </h2>
        <p class="text-sm text-slate-600 mt-3 leading-relaxed">
          {post.data.description}
        </p>
        {post.data.tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-1.5">
            {post.data.tags.map((t) => (
              <span class="text-xs bg-slate-100 text-slate-700 px-2 py-1 rounded">#{t}</span>
            ))}
          </div>
        )}
      </a>
    ))}
  </section>
</Base>
