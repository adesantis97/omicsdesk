---
import Base from '../layouts/Base.astro';

const stops = [
  {
    img: '/sample-report-tour/report_cover.png',
    title: '1. The branded PDF — cover + executive summary',
    body: "Every report opens with a one-page executive summary that answers the biology question in plain English — written so a CSO can read it in 90 seconds and a methods reviewer can audit it. No jargon dump, no template padding.",
  },
  {
    img: '/sample-report-tour/pca.png',
    title: '2. QC and study-design sanity check',
    body: "Before any downstream stats, the report shows what the data looked like — sample-level PCA, library-quality summary, batch checks. If the design has a problem, you see it on page 3, not buried in supplementary.",
  },
  {
    img: '/sample-report-tour/volcano.png',
    title: '3. Differential expression — named, not generic',
    body: "Volcano plots with named genes (not just dots), top hits labelled, thresholds explicit. The narrative on the facing page calls out which genes matter biologically and why — not just \"15 genes were upregulated\".",
  },
  {
    img: '/sample-report-tour/pathway.png',
    title: '4. Pathway enrichment with interpretation',
    body: "GO BP, KEGG, and Reactome enrichment tables, ordered by adjusted p-value. The narrative ties top pathways back to the original biology question — e.g. \"the type-I interferon axis is the dominant response, consistent with the proposed mechanism\".",
  },
  {
    img: '/sample-report-tour/tf_activity.png',
    title: '5. Transcription-factor activity inference',
    body: "DoRothEA + decoupleR — moves the analysis up one level of abstraction from gene lists to regulators. The report names which TFs are activated/repressed and how that maps onto the pathway story.",
  },
  {
    img: '/sample-report-tour/heatmap.png',
    title: '6. Heatmap of top genes across all samples',
    body: "Every report ships a top-DEG heatmap so the reader can visually confirm the contrast separates as expected — and inspect any outlier samples or unexpected groupings.",
  },
  {
    img: '/sample-report-tour/workbook.png',
    title: '7. Excel workbook — full statistical results',
    body: "The PDF is the narrative; the workbook is the full table. One sheet per contrast (DESeq2 results, log2FC, padj, gene symbol), one per pathway enrichment, one per TF activity. Sortable, filterable, ready to drop into a slide deck.",
  },
];
---
<Base
  title="Sample report tour — OmicsDesk"
  description="Walk through what a real OmicsDesk PDF report looks like, page by page — exec summary, QC, DE, pathways, TF activity, workbook."
>
  <header class="max-w-3xl mx-auto px-5 pt-20 pb-10">
    <p class="text-accent font-medium text-sm tracking-wide uppercase mb-4">Sample report tour</p>
    <h1 class="text-3xl sm:text-5xl font-bold tracking-tight leading-[1.05]">
      What a real report <span class="text-accent">actually looks like.</span>
    </h1>
    <p class="mt-6 text-lg text-slate-600 leading-relaxed">
      Seven stops through a real RNA-seq report — the same format every client
      receives. No marketing copy, no mockups — these are screenshots from the
      delivered PDF.
    </p>
    <div class="mt-6 flex flex-wrap gap-3">
      <a href="/case-studies/geo-melanoma/deliverables.zip" download class="inline-flex items-center gap-2 bg-ink text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-slate-800 transition">
        Download deliverables (PDF + workbook + figures)
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
      </a>
      <a href="/case-studies/geo-melanoma/" class="inline-flex items-center gap-2 border border-slate-300 text-ink px-4 py-2 rounded-md text-sm font-medium hover:bg-slate-50 transition">
        Read the case study →
      </a>
    </div>
  </header>

  <section class="max-w-3xl mx-auto px-5 pb-20 space-y-16">
    {stops.map((s) => (
      <div>
        <figure class="border border-slate-200 rounded-lg overflow-hidden bg-slate-50">
          <img src={s.img} alt={s.title} class="w-full block" />
        </figure>
        <div class="mt-5">
          <h2 class="text-xl font-semibold tracking-tight">{s.title}</h2>
          <p class="prose-p mt-2 max-w-2xl">{s.body}</p>
        </div>
      </div>
    ))}
  </section>

  <section class="bg-slate-50 border-y border-slate-100">
    <div class="max-w-3xl mx-auto px-5 py-14">
      <h2 class="text-xl sm:text-2xl font-semibold tracking-tight">Want this format on your data?</h2>
      <p class="prose-p mt-3">Fixed-fee, 7–10 business days, the same report format you see here.</p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href="mailto:hello@omicsdesk.com?subject=OmicsDesk%20%E2%80%94%20request%20a%20quote" class="inline-flex items-center gap-2 bg-ink text-white px-5 py-3 rounded-md font-medium hover:bg-slate-800 transition">
          Request a quote
        </a>
        <a href="/case-studies/" class="inline-flex items-center gap-2 border border-slate-300 text-ink px-5 py-3 rounded-md font-medium hover:bg-white transition">
          See more case studies
        </a>
      </div>
    </div>
  </section>
</Base>
