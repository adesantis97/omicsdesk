---
import Base from '../layouts/Base.astro';

interface Omics {
  slug: string;
  name: string;
  tagline: string;
  price: string;
  upTo: string;
  turnaround: string;
  deliverables: string[];
}

const services: Omics[] = [
  {
    slug: 'rnaseq',
    name: 'RNA-seq (bulk)',
    tagline: 'Splice-aware alignment, DESeq2 differential expression, GSEA, TF activity inference.',
    price: '€2,500',
    upTo: '24 samples',
    turnaround: '7 business days',
    deliverables: [
      'Adapter trimming + QC (fastp + MultiQC)',
      'Splice-aware alignment + gene quantification',
      'DESeq2 differential expression with shrinkage',
      'PCA, volcano plot, heatmap of top DEGs',
      'GSEA: GO, KEGG, Reactome',
      'TF activity inference (DoRothEA / decoupleR)',
    ],
  },
  {
    slug: 'scrnaseq',
    name: 'scRNA-seq',
    tagline: 'Cell-level QC, clustering, automated annotation, cross-condition DE.',
    price: '€3,500',
    upTo: '16 libraries',
    turnaround: '10 business days',
    deliverables: [
      'Cell-level QC, doublet removal, normalization',
      'UMAP / t-SNE + Leiden clustering',
      'Automated cell type annotation (CellTypist)',
      'Marker gene identification per cluster',
      'Differential expression across conditions / clusters',
      'AnnData object (.h5ad) included',
    ],
  },
  {
    slug: 'proteomics',
    name: 'Proteomics',
    tagline: 'MaxQuant / DIA-NN / FragPipe ingest, MSstats DA, pathway enrichment.',
    price: '€3,000',
    upTo: '24 samples',
    turnaround: '7 business days',
    deliverables: [
      'Search-engine ingest (MaxQuant, DIA-NN, FragPipe)',
      'Protein quantification matrix (LFQ, TMT, SILAC)',
      'MSstats / limma differential abundance',
      'PCA, volcano plot, heatmap',
      'GO, KEGG, Reactome enrichment',
    ],
  },
  {
    slug: 'phosphoproteomics',
    name: 'Phosphoproteomics',
    tagline: 'Proteomics + phosphosite quantification + kinase activity networks.',
    price: '€3,500',
    upTo: '24 samples',
    turnaround: '10 business days',
    deliverables: [
      'All proteomics deliverables',
      'Phosphosite-level quantification',
      'Kinase activity inference (KSEA / decoupleR)',
      'Kinase–substrate network visualization',
    ],
  },
  {
    slug: 'chipseq',
    name: 'ChIP-seq',
    tagline: 'Bowtie2 + MACS3 narrow/broad peaks, ChIPseeker annotation, HOMER motifs.',
    price: '€2,500',
    upTo: '24 samples',
    turnaround: '7 business days',
    deliverables: [
      'Adapter trimming + alignment (Bowtie2)',
      'Peak calling (MACS3) — narrow or broad',
      'Peak annotation (ChIPseeker)',
      'Motif enrichment analysis (HOMER)',
      'Differential binding (DiffBind, if applicable)',
      'BED / narrowPeak files included',
    ],
  },
  {
    slug: 'atacseq',
    name: 'ATAC-seq',
    tagline: 'BAMPE peak calling, ENCODE QC thresholds, optional TF footprinting.',
    price: '€2,500',
    upTo: '24 samples',
    turnaround: '7 business days',
    deliverables: [
      'Adapter trimming + alignment (Bowtie2)',
      'Accessible region calling (MACS3 BAMPE)',
      'TSS enrichment + fragment-size QC (ENCODE)',
      'Nucleosome positioning',
      'Optional TF footprinting (TOBIAS)',
      'Differential accessibility (DiffBind, if applicable)',
    ],
  },
];
---
<Base
  title="Pricing — OmicsDesk"
  description="Productized bioinformatics analysis. Fixed prices, fixed scopes, fixed turnarounds for RNA-seq, scRNA-seq, proteomics, phosphoproteomics, ChIP-seq, ATAC-seq, and multi-omics integration."
>
  <header class="max-w-5xl mx-auto px-5 pt-16 pb-10">
    <p class="text-accent font-medium text-sm tracking-wide uppercase mb-3">Productized pricing</p>
    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight">
      Fixed price. Fixed scope. Fixed turnaround.
    </h1>
    <p class="mt-5 text-lg text-slate-600 max-w-2xl leading-relaxed">
      Each service below is a complete end-to-end engagement: from FASTQ (or raw MS) to a branded PDF report, statistical workbook, figures, and reproducible pipeline code. Quote back within 2 business days.
    </p>
  </header>

  <section class="max-w-5xl mx-auto px-5 pb-16 grid md:grid-cols-2 gap-6">
    {services.map((s) => (
      <article id={s.slug} class="bg-white rounded-xl border border-slate-200 p-6 flex flex-col">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h2 class="text-xl font-semibold text-ink">{s.name}</h2>
            <p class="text-sm text-slate-600 mt-1">{s.tagline}</p>
          </div>
          <div class="text-right shrink-0">
            <div class="text-2xl font-bold font-mono text-ink">{s.price}</div>
          </div>
        </div>
        <dl class="mt-5 grid grid-cols-2 gap-3 text-sm">
          <div class="bg-slate-50 rounded p-3">
            <dt class="text-slate-500 text-xs uppercase tracking-wide">Up to</dt>
            <dd class="font-medium text-ink mt-0.5">{s.upTo}</dd>
          </div>
          <div class="bg-slate-50 rounded p-3">
            <dt class="text-slate-500 text-xs uppercase tracking-wide">Turnaround</dt>
            <dd class="font-medium text-ink mt-0.5">{s.turnaround}</dd>
          </div>
        </dl>
        <ul class="mt-5 space-y-1.5 text-sm text-slate-600 flex-grow">
          {s.deliverables.map((d) => (
            <li class="flex gap-2">
              <span class="text-accent shrink-0 mt-1.5">•</span>
              <span>{d}</span>
            </li>
          ))}
        </ul>
        <a
          href="https://submit.omicsdesk.com/"
          class="mt-6 inline-flex items-center justify-center gap-2 bg-ink text-white px-4 py-2.5 rounded-md font-medium text-sm hover:bg-slate-800 transition"
        >
          Start project
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </article>
    ))}
  </section>

  <section class="bg-slate-50 border-y border-slate-100">
    <div class="max-w-5xl mx-auto px-5 py-14 grid md:grid-cols-2 gap-6">
      <div class="bg-white rounded-xl border border-slate-200 p-6">
        <h3 class="text-lg font-semibold">Multi-omics integration</h3>
        <p class="text-sm text-slate-600 mt-2">
          Combine 2+ omics layers into one integrated analysis with patient-specific regulatory networks.
        </p>
        <div class="mt-4 space-y-2 text-sm">
          <div class="flex justify-between border-b border-slate-100 pb-2">
            <span>Integration base fee</span>
            <span class="font-mono font-semibold">€2,000</span>
          </div>
          <div class="flex justify-between text-slate-500">
            <span>+ each individual omics</span>
            <span>at list price</span>
          </div>
        </div>
        <p class="text-sm text-slate-500 mt-4">
          Example: <span class="text-ink">RNA-seq + Proteomics + Integration = <span class="font-mono">€7,500</span></span>.
          Includes MOFA2 factor analysis, patient-specific regulatory network, cross-omics pathway convergence, integrated PDF report.
        </p>
      </div>

      <div class="bg-white rounded-xl border border-slate-200 p-6">
        <h3 class="text-lg font-semibold">Add-ons</h3>
        <ul class="mt-4 space-y-2 text-sm">
          <li class="flex justify-between border-b border-slate-100 pb-2">
            <span>Rush delivery (3 business days)</span>
            <span class="font-mono font-semibold">+50%</span>
          </li>
          <li class="flex justify-between border-b border-slate-100 pb-2">
            <span>Extra samples (per batch of 6)</span>
            <span class="font-mono font-semibold">+€250</span>
          </li>
          <li class="flex justify-between">
            <span>Follow-up re-analysis (≤2 changes)</span>
            <span class="font-mono font-semibold">+€400</span>
          </li>
        </ul>
        <p class="text-sm text-slate-500 mt-4">
          15% academic discount on all services (excluding rush) for requests from
          <span class="font-mono text-slate-600">.edu</span> / <span class="font-mono text-slate-600">.ac.*</span> emails.
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-5 py-16">
    <div class="rounded-xl border-2 border-dashed border-slate-200 p-8 md:p-10">
      <p class="text-accent font-medium text-sm tracking-wide uppercase mb-2">Custom &amp; enterprise</p>
      <h2 class="text-2xl font-semibold tracking-tight">Outside the standard scope?</h2>
      <p class="text-slate-600 mt-3 max-w-2xl">
        Studies above 24 samples, white-label work for CROs, ongoing analysis retainers, novel omics
        types (spatial, Hi-C, long-read), or unusual reference genomes are all quotable. Email with the
        details — quote back within 2 business days.
      </p>
      <a
        href="mailto:hello@omicsdesk.com?subject=Custom%20engagement%20enquiry"
        class="mt-6 inline-flex items-center gap-2 bg-ink text-white px-5 py-3 rounded-md font-medium hover:bg-slate-800 transition"
      >
        Discuss a custom engagement
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-5 pb-16">
    <h2 class="text-xl font-semibold tracking-tight">Standard deliverables (every analysis)</h2>
    <ul class="mt-4 grid sm:grid-cols-2 gap-x-6 gap-y-1.5 text-sm text-slate-600 max-w-3xl">
      <li>QC report (HTML + summary table)</li>
      <li>Full statistical results (TSV + Excel workbook)</li>
      <li>Publication-ready figures (PNG, 300 dpi)</li>
      <li>Branded PDF report (executive summary, methods, conclusions)</li>
      <li>Reproducible pipeline code (Snakemake + conda)</li>
      <li>NDA available; raw data deleted within 30 days</li>
    </ul>
    <p class="mt-6 text-sm text-slate-500">
      Payment: 25% upfront / 75% on delivery for first engagement; 50/50 for returning clients.
      EUR by default; USD invoicing available on request.
    </p>
  </section>
</Base>
