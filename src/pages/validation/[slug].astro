---
import Base from '../../layouts/Base.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const runs = await getCollection('validation');
  return runs.map((r) => ({ params: { slug: r.slug }, props: { r } }));
}

type Props = { r: CollectionEntry<'validation'> };
const { r } = Astro.props as Props;
const { Content } = await r.render();
---
<Base title={`${r.data.title} — OmicsDesk validation`} description={r.data.recoveryMetric}>
  <header class="max-w-3xl mx-auto px-5 pt-16 pb-8">
    <p class="text-accent font-medium text-sm tracking-wide uppercase mb-4">Validation · {r.data.omicsType}</p>
    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight leading-tight">{r.data.title}</h1>
  </header>

  <section class="max-w-3xl mx-auto px-5">
    <figure>
      <img src={r.data.heroImage} alt={r.data.heroAlt} class="w-full rounded-lg border border-slate-200" />
      <figcaption class="mt-2 text-xs text-slate-500 italic">{r.data.heroAlt}</figcaption>
    </figure>
  </section>

  <section class="max-w-3xl mx-auto px-5 mt-10 space-y-6">
    <div class="rounded-lg border border-slate-200 bg-white p-5">
      <h2 class="text-xs uppercase tracking-wide font-medium text-slate-500">Dataset</h2>
      <p class="mt-2 text-slate-700 leading-relaxed">{r.data.dataset}</p>
    </div>
    <div class="rounded-lg border border-slate-200 bg-white p-5">
      <h2 class="text-xs uppercase tracking-wide font-medium text-slate-500">Ground truth</h2>
      <p class="mt-2 text-slate-700 leading-relaxed">{r.data.groundTruth}</p>
    </div>
    <div class="rounded-lg border border-accent/30 bg-accent/5 p-5">
      <h2 class="text-xs uppercase tracking-wide font-medium text-accent">Recovery</h2>
      <p class="mt-2 text-slate-700 leading-relaxed">{r.data.recoveryMetric}</p>
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-5 mt-10 prose prose-slate max-w-none prose-p:text-slate-700 prose-p:leading-relaxed">
    <Content />
  </section>

  <section class="max-w-3xl mx-auto px-5 mt-12 pb-20">
    <div class="bg-slate-50 border border-slate-200 rounded-xl p-6">
      <h3 class="font-semibold">Run this on your data</h3>
      <p class="prose-p text-sm mt-2">Same pipeline, fixed-fee, 7–10 business days. Email with your omics type and sample count.</p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="mailto:hello@omicsdesk.com?subject=OmicsDesk%20%E2%80%94%20request%20a%20quote" class="inline-flex items-center gap-2 bg-ink text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-slate-800 transition">
          Request a quote
        </a>
        <a href="/pricing/" class="inline-flex items-center gap-2 border border-slate-300 text-ink px-4 py-2 rounded-md text-sm font-medium hover:bg-white transition">
          See pricing
        </a>
        <a href="/validation/" class="inline-flex items-center gap-2 text-slate-600 px-4 py-2 rounded-md text-sm font-medium hover:text-ink transition">
          ← All validation runs
        </a>
      </div>
    </div>
  </section>
</Base>
