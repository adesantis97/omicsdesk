---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const runs = (await getCollection('validation')).sort(
  (a, b) => a.data.order - b.data.order,
);
---
<Base
  title="Pipeline validation — OmicsDesk"
  description="Every OmicsDesk pipeline benchmarked against a public ground-truth dataset. Recovery metrics, source data, and reproducibility evidence for RNA-seq, scRNA-seq, ATAC-seq, proteomics, phosphoproteomics, and WGS."
>
  <header class="max-w-5xl mx-auto px-5 pt-20 pb-12">
    <p class="text-accent font-medium text-sm tracking-wide uppercase mb-4">Validation</p>
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight leading-[1.05]">
      Every pipeline,<br />
      <span class="text-accent">benchmarked against ground truth.</span>
    </h1>
    <p class="mt-6 text-lg text-slate-600 max-w-2xl leading-relaxed">
      For each omics pipeline we run a published reference dataset end-to-end and
      report what was recovered versus what was expected. This is the technical
      evidence behind the case studies — same code paths, public data, verifiable
      results.
    </p>
    <p class="mt-3 text-sm text-slate-500 max-w-2xl">
      For real client deliverables in plain English, see <a class="text-accent underline-offset-4 hover:underline" href="/case-studies/">/case-studies</a>.
    </p>
  </header>

  <section class="max-w-5xl mx-auto px-5 pb-20">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {runs.map((r) => (
        <a
          href={`/validation/${r.slug}/`}
          class="group block bg-white rounded-lg border border-slate-200 overflow-hidden hover:border-accent transition"
        >
          <div class="aspect-[4/3] bg-slate-50 overflow-hidden border-b border-slate-100">
            <img src={r.data.heroImage} alt={r.data.heroAlt} class="w-full h-full object-cover group-hover:scale-[1.02] transition" />
          </div>
          <div class="p-5">
            <span class="bg-accent/10 text-accent text-xs uppercase tracking-wide font-medium px-2 py-0.5 rounded-sm">{r.data.omicsType}</span>
            <h2 class="mt-3 text-base font-semibold tracking-tight leading-snug group-hover:text-accent transition">{r.data.title}</h2>
            <p class="mt-3 text-xs text-slate-500 line-clamp-3 leading-relaxed">{r.data.dataset}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="bg-slate-50 border-y border-slate-100">
    <div class="max-w-5xl mx-auto px-5 py-14">
      <h2 class="text-xl sm:text-2xl font-semibold tracking-tight">How to read these</h2>
      <p class="prose-p mt-3 max-w-3xl text-sm">
        Each validation run takes a publicly-available dataset where the expected
        biological signal is already published, processes it through the production
        OmicsDesk pipeline unmodified, and reports what was recovered. A pipeline
        that can recover canonical signals on public data is the same pipeline that
        will be run on your data — the code path is identical.
      </p>
    </div>
  </section>
</Base>
